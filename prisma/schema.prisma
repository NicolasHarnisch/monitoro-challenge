generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Incident {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId
  machineName      String
  reason           String
  typeOfOccurrence String
  isMachineStopped Boolean  @default(false)
  description      String
  severity         String
  status           String   @default("Concluído")
  createdAt        DateTime @default(now())
}
